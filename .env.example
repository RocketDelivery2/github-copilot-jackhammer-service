# Required
OPENAI_API_KEY=sk-...
GITHUB_TOKEN=github_pat_...
GITHUB_OWNER=RocketDelivery2
GITHUB_REPO=TeamBuilder
REPO_URL=https://github.com/RocketDelivery2/TeamBuilder.git

# Defaults are safe; override as needed
BASE_BRANCH=main
WORK_BRANCH=ai/jackhammer-queue
OPENAI_MODEL=gpt-5.5
POLL_SECONDS=900
MAX_TASKS_PER_RUN=3
MAX_CONTEXT_FILES=80
MAX_CONTEXT_BYTES=450000
QUEUE_DIR=.ai/jackhammer-queue
STATE_FILE=.ai/state.json
DRY_RUN=false

# Optional: programmatically assign issues if your GitHub org exposes a Copilot assignee login.
# Leave blank unless you have confirmed the exact assignable login in your repo.
COPILOT_ASSIGNEE=

# Optional labels created/used by the service
ISSUE_LABELS=ai-task,jackhammer-queue
